# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude AI for scoring and feasibility

# ── Free Data Sources (always active) ─────────────────────────────────────────
# Census API — free, no key required (optional key increases rate limits)
CENSUS_API_KEY=                        # Free: api.census.gov/data/key_signup.html
# County ArcGIS / Socrata — free, no keys needed (15 counties configured)

# ── Paid Data Sources (~$130-280/month total) ────────────────────────────────
GOOGLE_PLACES_API_KEY=                 # ~$30-80/mo: console.cloud.google.com

# StorTrack — self-storage rate data ($79-199/mo: stortrack.com)
# Uses OAuth2 Password Flow (username + password, NOT an API key)
STORTRACK_USERNAME=                    # Your StorTrack account email
STORTRACK_PASSWORD=                    # Your StorTrack account password

# TractIQ — occupancy data (contact for pricing: tractiq.com)
TRACTIQ_API_KEY=                       # tractiq.com

# ESRI Demographics (enhanced demographics, optional)
ESRI_API_KEY=
# SerpAPI (broker search, optional)
SERPAPI_KEY=
# Auth token (set to require X-Auth-Token header on API requests)
AUTH_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3784
