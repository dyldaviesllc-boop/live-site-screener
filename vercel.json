{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/brokers/:brokerId/sites/:resultId", "destination": "/api/brokers/:brokerId?sub=sites&resultId=:resultId" },
    { "source": "/api/brokers/:brokerId/sites", "destination": "/api/brokers/:brokerId?sub=sites" },
    { "source": "/api/results/:resultId/broker", "destination": "/api/results/:resultId?sub=broker" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
